{
  "name": "cibilbazaar-dialer",
  "productName": "CibilBazaar Dialer",
  "version": "1.0.0",
  "description": "CibilBazaar Dialer - Offline CRM Dialer with Bluetooth/USB/WiFi bridge to Android",
  "main": "dist/main/main.js",
  "author": "CibilBazaar",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "build": "npm run build:main && npm run build:renderer && npm run copy:assets",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "copy:assets": "node scripts/copy-assets.js",
    "start": "npm run build && electron .",
    "dev": "tsc -p tsconfig.json -w",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "exceljs": "^4.4.0",
    "serialport": "^12.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.12",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.cibilbazaar.dialer",
    "productName": "CibilBazaar Dialer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CibilBazaar Dialer"
    }
  }
}
